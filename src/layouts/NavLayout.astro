---
import RootLayout from "./RootLayout.astro";
import NavBar from "../components/NavBar.astro";
import PageFooter from "../components/PageFooter.astro";

const { title = '' } = Astro.props;
---

<RootLayout title={title}>
    <NavBar/>

    <main class="flex-grow">
        <slot/>
    </main>

    <PageFooter/>
</RootLayout>