---
import { homePage } from "../globals"
import RootLayout from "../layouts/RootLayout.astro"
---

<RootLayout title="Error 404">
    <div class="flex flex-col items-center justify-center h-screen">
        <div class="text-center">
            <h1 class="text-4xl p-4 text-[#0dee4d] font-bold">- ERROR 404 -</h1>
            <h3 class="text-2xl pb-4">Page Not Found</h3>
            <a href={homePage} class="text-2xl bg-[#212121] hover:bg-[#313131] py-1 px-4 border-2 text-shadow-xl/100 border-white rounded-md text-shadow-md/100 hover:text-shadow-lg/100 transition-colors duration-300 ease-in-out">
                Return Home
            </a>
        </div>
    </div>
</RootLayout>