---
import { homePage } from "../globals"
import NavLink from "../components/NavLink.astro"
import RootLayout from "../layouts/RootLayout.astro"
---

<RootLayout title="Error 404">
    <div class="flex flex-col items-center justify-center h-screen">
        <div class="text-center">
            <h1 class="text-4xl p-4 text-[#0dee4d] font-bold">- ERROR 404 -</h1>
            <h3 class="text-2xl pb-2">Page Not Found</h3>
            <NavLink href={homePage} addClass="text-2xl">Clck Here To Return Home</NavLink>
        </div>
    </div>
</RootLayout>