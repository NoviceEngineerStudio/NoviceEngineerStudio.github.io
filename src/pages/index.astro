---
import NavLayout from "../layouts/NavLayout.astro";
---

<NavLayout class="bg-checkerboard bg-blue-500 bg-size-[75px_75px] flex justify-center w-screen h-screen bg-center">
    <threejs-panel />
</NavLayout>


<script>
import * as THREE from 'three';

export default class Sketch extends HTMLElement {
    private width: number = 0;
    private height: number = 0;

    private time: number = 0;

    private renderer: THREE.WebGLRenderer;
    private camera: THREE.PerspectiveCamera;
    private scene: THREE.Scene;

    private mesh: THREE.Mesh;

	constructor() {
        super();

		this.width = this.offsetWidth;
		this.height = this.offsetHeight;

		this.camera = new THREE.PerspectiveCamera( 70, this.width / this.height, 0.01, 10 );
		this.camera.position.z = 1;

		this.scene = new THREE.Scene();

		this.renderer = new THREE.WebGLRenderer( { antialias: true } );
		this.renderer.setPixelRatio(window.devicePixelRatio);

        const clearColor: THREE.Color = new THREE.Color(0, 0, 0);
        this.renderer.setClearColor(clearColor, 0)
		this.renderer.setPixelRatio(2);

		this.appendChild(this.renderer.domElement);

		this.time = 0;
		this.resize();
        
        const geometry = new THREE.BoxGeometry( 0.2, 0.2, 0.2 );
		const material = new THREE.MeshNormalMaterial();

		this.mesh = new THREE.Mesh( geometry, material );
		this.scene.add( this.mesh );

		this.render();

		window.addEventListener('resize', this.resize.bind(this));
	}

	resize(){
		this.width = this.offsetWidth;
		this.height = this.offsetHeight;
		this.renderer.setSize( this.width, this.height );
		this.camera.aspect = this.width / this.height;
		this.camera.updateProjectionMatrix();
	}

	render(){
		this.time += 0.05
		this.mesh.rotation.x = this.time;
		this.mesh.rotation.y = this.time;

		this.renderer.render( this.scene, this.camera );
        
		requestAnimationFrame(this.render.bind(this));
	}
}

customElements.define("threejs-panel", Sketch);
</script>