---
import NavLayout from "../layouts/NavLayout.astro";
---

<NavLayout>
    <div class="bg-[#252525] h-100 flex justify-left items-center relative mb-10">
        <div class="bg-[url(images/SpaceBoy.webp)] bg-left bg-no-repeat bg-contain h-full w-100"></div>

        <div class="text-xl text-shadow-lg/100">
            <h3>Hello!</h3>
            <h3>I'm Skyler!</h3>

            <div class="hidden sm:flex">
                <h3 class="relative">And I'm A:
                    <div class="absolute left-0 flex text-[#0dee4d]">
                        <h3 id="hero-title" class="whitespace-nowrap"></h3>
                        <h3 class="animate-pulse">|</h3>
                    </div>
                </h3>
            </div>

            <div class="flex sm:hidden">
                <h3>And I'm A:
                    <div class="text-[#0dee4d]">
                        <h3 id="hero-title">
                            GAME DEVELOPER|
                        </h3>
                    </div>
                </h3>
            </div>
        </div>

        <div class="h-25 w-full absolute bottom-0 bg-linear-to-t from-black to-[#25252500]"></div>
    </div>

    <div class="flex flex-col md:flex-row items-center justify-center gap-8 p-4">
        <img src="/images/SpaceBoy.webp" alt="AboutPicture" loading="lazy" class="w-1/2 md:w-1/3 object-cover border-2 border-white" />
        <div class="flex flex-col items-center justify-center text-center gap-4">
            <h3 class="text-xl font-bold">- About Me -</h3>
            <p>
                My name is Skyler, and I'm a programmer with a passion for game development. Through games, I've found that I enjoy creating experiences that bring joy to others while also challenging myself to learn and grow. This website serves as a place for me to showcase my projects, share my thoughts, and connect with others who share similar interests. Whether you're a fellow developer, a gamer, or just curious about what I do, I hope you find something here that resonates with you.
            </p>
        </div>
    </div>

    <script type="module" is:inline>
        const heroTitle = document.getElementById('hero-title');

        const STATE_TYPING = 0;
        const STATE_WAITING = 1;
        const STATE_DELETING = 2;

        let typeState = STATE_TYPING;
        let titleIndex = 0;
        let charIndex = 0;

        const typeRate = 100;
        const waitTime = 1500;
        const titles = [
            "GAME DEVELOPER",
            "PROGRAMMER",
            "GAMER",
            "ENGINEER",
        ];

        setInterval(() => {
            const title = titles[titleIndex];
            
            switch (typeState) {
                case STATE_TYPING:
                    if (charIndex <= title.length) {
                        heroTitle.textContent = title.substring(0, charIndex);
                        charIndex++;
                    }
                    else {
                        charIndex = title.length - 1;
                        typeState = STATE_WAITING;

                        setTimeout(() => {
                            typeState = STATE_DELETING;
                        }, waitTime);
                    }
                    break;

                case STATE_WAITING:
                    break;

                case STATE_DELETING:
                    if (charIndex >= 0) {
                        heroTitle.textContent = title.substring(0, charIndex);
                        charIndex--;
                    }
                    else {
                        titleIndex = (titleIndex + 1) % titles.length;
                        charIndex = 0;
                        typeState = STATE_WAITING;

                        setTimeout(() => {
                            typeState = STATE_TYPING;
                        }, waitTime);
                    }
                    break;
            
                default:
                    typeState = STATE_TYPING;
                    titleIndex = 0;
                    charIndex = 0;
                    break;
            }
        }, typeRate);
    </script>
</NavLayout>